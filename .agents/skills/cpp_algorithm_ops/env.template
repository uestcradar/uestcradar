# ========================================================================
# C++ 雷达算法分布式部署环境配置模板 (env.template)
# ========================================================================

# 📡 1. 目标物理雷达节点网络参数
REMOTE_IP="192.162.2.32"        # 目标物理机 IP 地址
REMOTE_USER="root"              # 登录用户名
REMOTE_PASS="111111"            # 登录密码 (用于自动化 sshpass)

# 🐳 2. Docker 容器化运行参数
USE_DOCKER="true"               # 目标机是否使用 Docker 运行 (true/false)
DOCKER_NAME="sim-du-node2"      # 容器服务名称 (例如 sim-du-node2 或 sim-du-node4)

# 📁 3. 代码路径与硬件架构定义
CODE_DIR="/home/workspace/cycore"  # 目标物理机上的 cycore 部署根路径 (用于定位挂载插件目录)
ARCH="arm"                      # 目标机系统 CPU 架构 (arm: 代表 AArch64 板卡 / x86: 代表普通 PC 开发机)
